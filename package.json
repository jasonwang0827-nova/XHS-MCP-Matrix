{
  "name": "xhs-mcp-matrix",
  "version": "0.1.0",
  "private": true,
  "description": "Xiaohongshu matrix MCP wrapper using local xiaohongshu-mcp service",
  "main": "dist/server/main.js",
  "scripts": {
    "dev": "tsx server/main.ts",
    "start:service": "tsx server/main.ts",
    "dev:check-upstream": "tsx server/dev-check-upstream.ts",
    "dev:check-login": "tsx server/dev-check-login.ts",
    "dev:list-accounts": "tsx server/dev-list-accounts.ts",
    "dev:create-account": "tsx server/dev-create-account.ts",
    "dev:start-account": "tsx server/dev-start-account.ts",
    "dev:stop-account": "tsx server/dev-stop-account.ts",
    "dev:check-account-login": "tsx server/dev-check-account-login.ts",
    "dev:check-two-accounts": "tsx server/dev-check-two-accounts.ts",
    "dev:verify-multi-account": "tsx server/dev-verify-multi-account.ts",
    "dev:list-clients": "tsx server/dev-list-clients.ts",
    "dev:safety-check": "tsx server/dev-safety-check.ts",
    "dev:reply-suggestion": "tsx server/dev-reply-suggestion.ts",
    "dev:search-plan": "tsx server/dev-search-plan.ts",
    "dev:enqueue-task": "tsx server/dev-enqueue-task.ts",
    "dev:list-tasks": "tsx server/dev-list-tasks.ts",
    "dev:run-next-task": "tsx server/dev-run-next-task.ts",
    "dev:run-task-by-id": "tsx server/dev-run-task-by-id.ts",
    "dev:run-scheduler-loop": "tsx server/dev-run-scheduler-loop.ts",
    "dev:add-publish-content": "tsx server/dev-add-publish-content.ts",
    "dev:generate-publish-task": "tsx server/dev-generate-publish-task.ts",
    "dev:read-publish-records": "tsx server/dev-read-publish-records.ts",
    "dev:scan-publish-videos": "tsx server/dev-scan-publish-videos.ts",
    "dev:openclaw-publish-video": "tsx server/dev-openclaw-publish-video.ts",
    "dev:run-matrix-discovery": "tsx server/dev-run-matrix-discovery.ts",
    "dev:run-daily-growth-plan": "tsx server/dev-run-daily-growth-plan.ts",
    "check": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/main.js"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
